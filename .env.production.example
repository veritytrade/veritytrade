# VerityTrade Production .env Template
# Copy this to your server as .env and fill in the values.
# Never commit .env to Git.

APP_NAME="VerityTrade"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=veritytrade_prod
DB_USERNAME=
DB_PASSWORD=

# Prefer file for single-server shared hosting (faster than database)
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=database
FILESYSTEM_DISK=public

# Super Admin – REQUIRED before db:seed (min 16 chars, never "password123")
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_PHONE=
SUPER_ADMIN_ADDRESS="Head Office"

# Email – use Authenticated SMTP (not PHP mail()). Match cPanel → Email → Connect Devices.
# Port 465 = SSL (below). Port 587 = use MAIL_PORT=587 and MAIL_ENCRYPTION=starttls instead.
MAIL_MAILER=smtp
MAIL_HOST=mail.veritytrade.ng
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=noreply@veritytrade.ng
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@veritytrade.ng
MAIL_FROM_NAME="${APP_NAME}"
