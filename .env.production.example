# VerityTrade Production .env Template
# Copy this to your server as .env and fill in the values.
# Never commit .env to Git.

APP_NAME="VerityTrade"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=veritytrade_prod
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=public

# Super Admin – REQUIRED before db:seed (min 16 chars, never "password123")
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_PHONE=
SUPER_ADMIN_ADDRESS="Head Office"

# Optional: for email features
# MAIL_MAILER=smtp
# MAIL_HOST=
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM_ADDRESS=
# MAIL_FROM_NAME="${APP_NAME}"
